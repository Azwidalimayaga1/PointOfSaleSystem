# Security
ServerSignature Off

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /
    # Never expose repository metadata or private operational data.
    RewriteRule ^\.git(?:/|$) - [F,L,NC]
    RewriteRule ^(?:backups|captured_photos)/ - [F,L,NC]
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^(.*)$ index.php?page=$1 [QSA,L]
</IfModule>

<FilesMatch "\.(sql|md|log|env|db|sqlite|sqlite3|bak)$">
    Require all denied
</FilesMatch>

<Files "config.php">
    Require all denied
</Files>

<Files "migrate_to_mysql.php">
    Require all denied
</Files>

<IfModule mod_autoindex.c>
    Options -Indexes
</IfModule>

<IfModule mod_headers.c>
    Header always set X-Frame-Options "DENY"
    Header always set X-Content-Type-Options "nosniff"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>
